-- ══════════════════════════════════════════
-- AUTO-HOP: Extract JobId from Terminal Response
-- ══════════════════════════════════════════
local function extractJobId(tbl)
    if type(tbl) == "string" and #tbl == 36 and tbl:match("%w+-%w+-%w+-%w+-%w+") then
        return tbl
    elseif type(tbl) == "table" then
        if tbl.jobId then return tbl.jobId, tbl.placeId end
        if tbl.JobId then return tbl.JobId, tbl.PlaceId end
        for _, v in pairs(tbl) do
            local j, p = extractJobId(v)
            if j then return j, p end
        end
    end
    return nil
end

-- ══════════════════════════════════════════
-- AUTO-HOP: Core Hop Logic
-- ══════════════════════════════════════════
local function doServerHop(statusLabel)
    if currentRunID ~= _G.BoothSniperRunID then return end -- Kill ghost

    if _G.BoothSniperSettings.TerminalSearch then
        if statusLabel then statusLabel.Text = "📡 Searching Trading Terminal..." end
        print("[BoothSniper] Initiating Terminal Search...")
        
        local network = ReplicatedStorage:WaitForChild("Network", 5)
        local terminalRemote = network and network:WaitForChild("TradingTerminal_Search", 5)
        
        if terminalRemote then
            for _, target in ipairs(_G.BoothSniperSettings.Items) do
                if target.ItemName then
                    local searchArgs = {}
                    searchArgs[1] = target.TerminalClass or target.Class:gsub("Items", "")
                    searchArgs[2] = '{"id":"' .. target.ItemName .. '"}'
                    searchArgs[4] = true
                    
                    local success, response = pcall(function()
                        return terminalRemote:InvokeServer(unpack(searchArgs))
                    end)
                    
                    if success and response then
                        local jobId, placeId = extractJobId(response)
                        if jobId and jobId ~= game.JobId then
                            print("[BoothSniper] Terminal found server! Teleporting...")
                            if statusLabel then statusLabel.Text = "🚀 Terminal Server Found! Teleporting..." end
                            TeleportService:TeleportToPlaceInstance(placeId or game.PlaceId, jobId, LocalPlayer)
                            task.wait(10)
                        end
                    end
                end
                task.wait(0.5)
            end
        end
    end

    if _G.BoothSniperSettings.RandomJoin then
        if statusLabel then statusLabel.Text = "🎲 Terminal empty. Random Hopping..." end
        print("[BoothSniper] Falling back to Random Server Hop...")
        
        local url = "https://games.roblox.com/v1/games/" .. game.PlaceId .. "/servers/Public?sortOrder=Desc&limit=100"
        local success, result = pcall(function() return game:HttpGet(url) end)
        
        if success then
            local data = HttpService:JSONDecode(result)
            if data and data.data then
                local validServers = {}
                for _, server in ipairs(data.data) do
                    if server.playing and server.maxPlayers and server.playing < server.maxPlayers and server.id ~= game.JobId then
                        table.insert(validServers, server.id)
                    end
                end
                
                if #validServers > 0 then
                    local randomJobId = validServers[math.random(1, #validServers)]
                    TeleportService:TeleportToPlaceInstance(game.PlaceId, randomJobId, LocalPlayer)
                    task.wait(10)
                end
            end
        end
    end
    
    isHopping = false
    timeInServer = 0 
end

-- ══════════════════════════════════════════
-- UTILITY: Fetch API & Parse Data
-- ══════════════════════════════════════════
local function fetchItemAssetID(class, itemName)
    local cacheKey = class .. "_" .. itemName
    if cachedAssetIDs[cacheKey] then return cachedAssetIDs[cacheKey] end

    local url = string.format("https://ps99.biggamesapi.io/api/collection/%s", class)
    local ok, result = pcall(function() return game:HttpGet(url) end)

    if ok and result then
        local decoded = HttpService:JSONDecode(result)
        if decoded and decoded.data then
            for _, itemData in pairs(decoded.data) do
                if itemData.configName and itemData.configName:lower() == itemName:lower() then
                    if itemData.configData and itemData.configData.Icon then
                        local id = tostring(itemData.configData.Icon):match("%d+")
                        if id then
                            cachedAssetIDs[cacheKey] = id
                            return id
                        end
                    end
                end
            end
        end
    end
    return nil
end

local function getCleanID(assetText) return assetText and tostring(assetText):match("%d+") or "" end

local function parsePrice(text)
    if type(text) ~= "string" then return 0 end
    text = text:lower():gsub(",", ""):gsub(" ", "")
    local suffixes = { t = 1e12, b = 1e9, m = 1e6, k = 1e3 }
    for suffix, mult in pairs(suffixes) do
        local num = text:match("([%d%.]+)" .. suffix)
        if num then return tonumber(num) * mult end
    end
    return tonumber(text:match("([%d%.]+)")) or 0
end

local function getGems()
    local ls = LocalPlayer:FindFirstChild("leaderstats")
    if not ls then return 0 end
    for _, stat in ipairs(ls:GetChildren()) do
        if stat.Name:match("Diamonds") or stat.Name:match("💎") then return tonumber(stat.Value) or 0 end
    end
    return 0
end

