-- ══════════════════════════════════════════
-- UTILITY: Normalize Asset ID
-- ══════════════════════════════════════════
local function getCleanID(assetText)
    if not assetText then return "" end
    return tostring(assetText):gsub("rbxassetid://", "")
end

-- ══════════════════════════════════════════
-- UTILITY: Parse price text (1k, 1m, 1b, 1t)
-- ══════════════════════════════════════════
local function parsePrice(text)
    if not text then return 0 end
    text = text:lower():gsub(",", ""):gsub(" ", "")
    local suffixes = { t = 1e12, b = 1e9, m = 1e6, k = 1e3 }
    for suffix, mult in pairs(suffixes) do
        local num = text:match("^(%d+%.?%d*)" .. suffix .. "$")
        if num then return tonumber(num) * mult end
    end
    return tonumber(text) or 0
end

-- ══════════════════════════════════════════
-- UTILITY: Get player gem count
-- ══════════════════════════════════════════
local function getGems()
    local ls = LocalPlayer:FindFirstChild("leaderstats")
    if not ls then return 0 end
    local diamonds = ls:FindFirstChild("\240\159\146\142 Diamonds") 
    return diamonds and diamonds.Value or 0
end

-- ══════════════════════════════════════════
-- CORE: Fire purchase remote
-- ══════════════════════════════════════════
local function purchaseItem(ownerID, itemGUID, amount)
    local remote = ReplicatedStorage:WaitForChild("Network"):WaitForChild("Booths_RequestPurchase")
    local args = {
        ownerID,
        { [itemGUID] = amount },
        {
            Caller = {
                LineNumber = 527,
                ScriptClass = "ModuleScript",
                Variadic = false,
                Traceback = "ReplicatedStorage.Library.Client.BoothCmds:527 function PromptPurchase2\nReplicatedStorage.Library.Client.BoothCmds:654 function promptOtherPlayerBooth2\nReplicatedStorage.Library.Client.BoothCmds:157",
                ScriptPath = "ReplicatedStorage.Library.Client.BoothCmds",
                FunctionName = "PromptPurchase2",
                Handle = "function: 0xfa15618739cde075",
                ScriptType = "Instance",
                ParameterCount = 2,
                SourceIdentifier = "ReplicatedStorage.Library.Client.BoothCmds"
            }
        }
    }
    return remote:InvokeServer(table.unpack(args))
end

-- ══════════════════════════════════════════
-- CORE: Scan all booths logic
-- ══════════════════════════════════════════
local function scanAllBooths(statusLabel)
    local boothsFolder = workspace:FindFirstChild("__THINGS") and workspace.__THINGS:FindFirstChild("Booths")
    if not boothsFolder then return end

    local myGems = getGems()
    local foundCount = 0

    for _, booth in ipairs(boothsFolder:GetChildren()) do
        local ownerID = booth:GetAttribute("Owner")
        if not ownerID or ownerID == LocalPlayer.UserId then continue end -- Skip empty or own booths

        local petScroll = booth:FindFirstChild("Pets")
            and booth.Pets:FindFirstChild("BoothTop")
            and booth.Pets.BoothTop:FindFirstChild("PetScroll")

        if petScroll then
            for _, itemBox in ipairs(petScroll:GetChildren()) do
                if itemBox:IsA("UIListLayout") or itemBox:IsA("UIPadding") then continue end

                local iconLabel = itemBox:FindFirstChild("Holder")
                    and itemBox.Holder:FindFirstChild("ItemSlot")
                    and itemBox.Holder.ItemSlot:FindFirstChild("Icon")

                if iconLabel and iconLabel:IsA("ImageLabel") then
                    local cleanFoundID = getCleanID(iconLabel.Image)

                    -- Check against configured targets
                    for _, target in ipairs(_G.BoothSniperSettings.Items) do
                        if cleanFoundID == getCleanID(target.AssetID) then
                            foundCount += 1
                            
                            local costLabel = itemBox:FindFirstChild("Buy")
                                and itemBox.Buy:FindFirstChild("Cost")
                                
                            if costLabel and costLabel:IsA("TextLabel") then
                                local pricePerItem = parsePrice(costLabel.Text)
                                
                                -- Check max price config
                                if pricePerItem > (target.MaxPrice or math.huge) then
                                    if statusLabel then
                                        statusLabel.Text = string.format("❌ Skipped (Overpriced): %s/ea", costLabel.Text)
                                        statusLabel.TextColor3 = Color3.fromRGB(230, 150, 80)
                                    end
                                    continue
                                end
                                
                                -- Calculate affordable amount
                                local stockAvailable = itemBox:GetAttribute("Quantity") or 1
                                local maxAffordable = math.floor(myGems / pricePerItem)
                                local buyAmount = math.min(maxAffordable, stockAvailable)
                                
                                if buyAmount > 0 then
                                    if statusLabel then
                                        statusLabel.Text = string.format("✔️ Buying %dx for %s gems/ea!", buyAmount, costLabel.Text)
                                        statusLabel.TextColor3 = Color3.fromRGB(100, 255, 130)
                                    end
                                    
                                    local guid = itemBox.Name
                                    task.spawn(function()
                                        purchaseItem(ownerID, guid, buyAmount)
                                    end)
                                    task.wait(0.2)
                                else
                                    if statusLabel then
                                        statusLabel.Text = "❌ Found target, but not enough gems."
                                        statusLabel.TextColor3 = Color3.fromRGB(230, 80, 80)
                                    end
                                end
                            end
                        end
                    end
                end
            end
        end
    end

    if foundCount == 0 and isScanning and statusLabel then
        statusLabel.Text = string.format("🔍 Scanning for %d targeted items...", #_G.BoothSniperSettings.Items)
        statusLabel.TextColor3 = Color3.fromRGB(180, 180, 255)
    end
end

