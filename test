-- ══════════════════════════════════════════
-- UTILITY: Fetch Item Data from OFFICIAL BIG GAMES API
-- ══════════════════════════════════════════
local function fetchItemAssetID(class, itemName)
    -- Check if we already fetched it to avoid spamming the API
    local cacheKey = class .. "_" .. itemName
    if cachedAssetIDs[cacheKey] then return cachedAssetIDs[cacheKey] end

    -- Connect directly to the official BIG Games PS99 Database
    local url = string.format("https://ps99.biggamesapi.io/api/collection/%s", class)
    
    local ok, result = pcall(function()
        return game:HttpGet(url)
    end)

    if ok and result then
        local decoded = HttpService:JSONDecode(result)
        
        -- The API wraps the item list inside a "data" array
        if decoded and decoded.data then
            for _, itemData in pairs(decoded.data) do
                -- Check if the item name matches what you configured
                if itemData.configName and itemData.configName:lower() == itemName:lower() then
                    if itemData.configData and itemData.configData.Icon then
                        -- Extract just the numbers from the rbxassetid:// string
                        local id = tostring(itemData.configData.Icon):gsub("rbxassetid://", "")
                        cachedAssetIDs[cacheKey] = id
                        return id
                    end
                end
            end
        end
    else
        warn("[BoothSniper] Failed to connect to BIG Games API for class:", class)
    end
    
    return nil
end

-- ══════════════════════════════════════════
-- UTILITY: Get player gem count
-- ══════════════════════════════════════════
local function getGems()
    local ls = LocalPlayer:FindFirstChild("leaderstats")
    if not ls then return 0 end
    local diamonds = ls:FindFirstChild("\240\159\146\142 Diamonds") 
    return diamonds and diamonds.Value or 0
end

-- ══════════════════════════════════════════
-- CORE: Fire purchase remote
-- ══════════════════════════════════════════
local function purchaseItem(ownerID, itemGUID, amount)
    local remote = ReplicatedStorage:WaitForChild("Network"):WaitForChild("Booths_RequestPurchase")
    local args = {
        ownerID,
        { [itemGUID] = amount },
        {
            Caller = {
                LineNumber = 527,
                ScriptClass = "ModuleScript",
                Variadic = false,
                Traceback = "ReplicatedStorage.Library.Client.BoothCmds:527 function PromptPurchase2\nReplicatedStorage.Library.Client.BoothCmds:654 function promptOtherPlayerBooth2\nReplicatedStorage.Library.Client.BoothCmds:157",
                ScriptPath = "ReplicatedStorage.Library.Client.BoothCmds",
                FunctionName = "PromptPurchase2",
                Handle = "function: 0xfa15618739cde075",
                ScriptType = "Instance",
                ParameterCount = 2,
                SourceIdentifier = "ReplicatedStorage.Library.Client.BoothCmds"
            }
        }
    }
    return remote:InvokeServer(table.unpack(args))
end

-- ══════════════════════════════════════════
-- PRE-LOAD: Resolve APIs before scanning
-- ══════════════════════════════════════════
local function preLoadTargets()
    for _, target in ipairs(_G.BoothSniperSettings.Items) do
        -- If they used the new Class/Item method instead of AssetID
        if target.Class and target.ItemName and not target.AssetID then
            local fetchedID = fetchItemAssetID(target.Class, target.ItemName)
            if fetchedID then
                target.AssetID = fetchedID
                print("[BoothSniper] Resolved API ID for", target.ItemName, "->", fetchedID)
            else
                warn("[BoothSniper] Could not find Asset ID for:", target.ItemName)
            end
        end
    end
end

-- ══════════════════════════════════════════
-- UTILITY: Parse price text (1k, 1m, 1b, 1t)
-- ══════════════════════════════════════════
local function parsePrice(text)
    if not text then return 0 end
    text = text:lower():gsub(",", ""):gsub(" ", ""):gsub("💎", "")

    local suffixes = { t = 1e12, b = 1e9, m = 1e6, k = 1e3 }
    for suffix, mult in pairs(suffixes) do
        local num = text:match("^(%d+%.?%d*)" .. suffix .. "$")
        if num then return tonumber(num) * mult end
    end

    local rawNum = text:match("^(%d+%.?%d*)$")
    return tonumber(rawNum) or 0
end

-- ══════════════════════════════════════════
-- CORE: Scan all booths logic
-- ══════════════════════════════════════════
local function scanAllBooths(statusLabel)
    local boothsFolder = workspace:FindFirstChild("__THINGS") and workspace.__THINGS:FindFirstChild("Booths")
    if not boothsFolder then return end

    local myGems = getGems()
    local foundCount = 0
    local uiUpdated = false

    for _, booth in ipairs(boothsFolder:GetChildren()) do
        local ownerID = booth:GetAttribute("Owner")
        if not ownerID or ownerID == LocalPlayer.UserId then continue end 

        local petScroll = booth:FindFirstChild("Pets")
            and booth.Pets:FindFirstChild("BoothTop")
            and booth.Pets.BoothTop:FindFirstChild("PetScroll")

        if petScroll then
            for _, itemBox in ipairs(petScroll:GetChildren()) do
                if itemBox:IsA("UIListLayout") or itemBox:IsA("UIPadding") then continue end

                local iconLabel = itemBox:FindFirstChild("Holder")
                    and itemBox.Holder:FindFirstChild("ItemSlot")
                    and itemBox.Holder.ItemSlot:FindFirstChild("Icon")

                if iconLabel and iconLabel:IsA("ImageLabel") then
                    local cleanFoundID = getCleanID(iconLabel.Image)

                    for _, target in ipairs(_G.BoothSniperSettings.Items) do
                        if target.AssetID and cleanFoundID == getCleanID(target.AssetID) then
                            foundCount += 1
                            
                            local costLabel = itemBox:FindFirstChild("Buy") and itemBox.Buy:FindFirstChild("Cost")
                                
                            if costLabel and costLabel:IsA("TextLabel") then
                                local pricePerItem = parsePrice(costLabel.Text)
                                local maxPrice = target.MaxPrice or math.huge
                                
                                print(string.format("[BoothSniper] Found target %s! Booth Price: %d | Your Max Price: %d", target.AssetID, pricePerItem, maxPrice))

                                if pricePerItem > maxPrice then
                                    if statusLabel then
                                        statusLabel.Text = string.format("❌ Skipped (Overpriced): %s", costLabel.Text)
                                        statusLabel.TextColor3 = Color3.fromRGB(230, 150, 80)
                                        uiUpdated = true
                                    end
                                    print("[BoothSniper] -> Skipped: Price too high.")
                                    continue
                                end
                                
                                local stockAvailable = itemBox:GetAttribute("Quantity") or 1
                                local maxAffordable = math.floor(myGems / pricePerItem)
                                local buyAmount = math.min(maxAffordable, stockAvailable)
                                
                                if buyAmount > 0 then
                                    if statusLabel then
                                        statusLabel.Text = string.format("✔️ Buying %dx for %s/ea!", buyAmount, costLabel.Text)
                                        statusLabel.TextColor3 = Color3.fromRGB(100, 255, 130)
                                        uiUpdated = true
                                    end
                                    
                                    print(string.format("[BoothSniper] -> Attempting to buy %d items...", buyAmount))
                                    local guid = itemBox.Name
                                    task.spawn(function()
                                        purchaseItem(ownerID, guid, buyAmount)
                                    end)
                                    task.wait(0.5)
                                else
                                    if statusLabel then
                                        statusLabel.Text = "❌ Found target, but not enough gems."
                                        statusLabel.TextColor3 = Color3.fromRGB(230, 80, 80)
                                        uiUpdated = true
                                    end
                                    print("[BoothSniper] -> Skipped: Not enough gems.")
                                end
                            end
                        end
                    end
                end
            end
        end
    end

    if isScanning and statusLabel and not uiUpdated then
        statusLabel.Text = string.format("🔍 Scanning for %d targeted items...", #_G.BoothSniperSettings.Items)
        statusLabel.TextColor3 = Color3.fromRGB(180, 180, 255)
    end
end

