local function getReqFunc()
    return (syn and syn.request) or (typeof(request)=="function" and request)
        or (typeof(http_request)=="function" and http_request) or nil
end

local function buildFleetEmbed(accounts)
    local now = os.time()
    local fields = {}
    local onlineCount = 0
    for _, acc in ipairs(accounts) do
        local age    = now - (acc.ts or 0)
        local online = age < STALE_SECS
        if online then onlineCount += 1 end
        local dot    = online and "🟢" or "🔴"
        table.insert(fields, {
            name  = dot.." "..tostring(acc.name or "?"),
            value = online
                and string.format("💎 `%s` | 🌱 `%s` | 🔷 `%s`\n📡 `%s`\n🏷️ %s",
                    tostring(acc.gems or 0),
                    tostring(acc.insta or 0),
                    tostring(acc.diamond or 0),
                    tostring(acc.server or "?"),
                    tostring(acc.status or "Running"))
                or "*Offline*",
            inline = false
        })
    end
    if #fields == 0 then
        table.insert(fields, {name="No accounts", value="Waiting...", inline=false})
    end
    return {
        embeds = {{
            title  = "🌸 PS99 Booth Sniper Fleet",
            color  = 0x64FF96,
            fields = fields,
            footer = { text = string.format("v3.8 • %d online • Updated %s",
                onlineCount, os.date("%H:%M:%S")) }
        }}
    }
end

local webhookBusy = false
local function pushWebhook(accounts)
    if WEBHOOK == "" then return end
    if webhookBusy then return end
    webhookBusy = true
    task.spawn(function()
        local reqFunc = getReqFunc()
        if not reqFunc then webhookBusy=false return end
        local body = buildFleetEmbed(accounts)
        local msgId = fileExists(MSGID_FILE) and safeReadText(MSGID_FILE) or ""
        msgId = msgId:match("^%s*(.-)%s*$")  -- trim whitespace
        if msgId ~= "" then
            -- PATCH existing shared message
            pcall(function()
                reqFunc({
                    Url     = WEBHOOK.."/messages/"..msgId,
                    Method  = "PATCH",
                    Headers = {["Content-Type"]="application/json"},
                    Body    = HttpService:JSONEncode(body)
                })
            end)
        else
            -- POST once, save message ID for all accounts
            pcall(function()
                local res = reqFunc({
                    Url     = WEBHOOK.."?wait=true",
                    Method  = "POST",
                    Headers = {["Content-Type"]="application/json"},
                    Body    = HttpService:JSONEncode(body)
                })
                if res and res.Body then
                    local ok, data = pcall(function() return HttpService:JSONDecode(res.Body) end)
                    if ok and data and data.id then
                        safeWriteText(MSGID_FILE, tostring(data.id))
                    end
                end
            end)
        end
        webhookBusy = false
    end)
end

-- throttled wrapper — never fires more than once per 15s
local lastWebhookPush = 0
local function scheduleWebhook(status, gems, insta, diamond)
    if WEBHOOK == "" then return end
    local accounts = updateMyStatus(status, gems, insta, diamond)
    local now = os.time()
    if (now - lastWebhookPush) >= 15 then
        lastWebhookPush = now
        pushWebhook(accounts)
    end
end

