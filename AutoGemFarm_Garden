local function parsePrice(text)
    if type(text) ~= "string" then return tonumber(text) or 0 end
    text = text:lower():gsub(",", ""):gsub(" ", "")
    for suffix, mult in pairs({ t = 1e12, b = 1e9, m = 1e6, k = 1e3 }) do
        local num = text:match("([%d%.]+)" .. suffix)
        if num then return tonumber(num) * mult end
    end
    return tonumber(text:match("([%d%.]+)")) or 0
end

local function getGems()
    local leaderstats = LocalPlayer:FindFirstChild("leaderstats")
    if not leaderstats then return 0 end
    
    for _, stat in ipairs(leaderstats:GetChildren()) do
        if stat.Name:match("Diamonds") or stat.Name:match("💎") then
            return parsePrice(tostring(stat.Value))
        end
    end
    return 0
end

