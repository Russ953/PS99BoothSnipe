local function cleanList(list)
    local now, out = os.time(), {}
    for _, e in ipairs(list) do
        if type(e)=="table" and e.jobId and (now-(e.ts or 0)) < STALE_SECS then
            table.insert(out, e)
        end
    end
    return out
end
local function removeSelf()
    local list = cleanList(safeReadJSON(TAKEN_FILE))
    local out = {}
    for _, e in ipairs(list) do if e.jobId ~= MY_JOB then table.insert(out, e) end end
    safeWriteJSON(TAKEN_FILE, out)
end
local function registerSelf()
    local list = cleanList(safeReadJSON(TAKEN_FILE))
    local out = {}
    for _, e in ipairs(list) do if e.jobId ~= MY_JOB then table.insert(out, e) end end
    table.insert(out, {jobId=MY_JOB, user=MY_NAME, ts=os.time()})
    safeWriteJSON(TAKEN_FILE, out)
end
local function isTaken(jobId)
    local now = os.time()
    for _, e in ipairs(safeReadJSON(TAKEN_FILE)) do
        if type(e)=="table" and e.jobId==jobId and (now-(e.ts or 0)) < STALE_SECS then return true end
    end
    return false
end
