local TAKEN_FILE  = "booth_taken_servers.json"
local STALE_SECS  = 35
local MY_JOB      = game.JobId

local function readTaken()
    if not pcall(isfile, TAKEN_FILE) then return {} end
    local ok, ok2, data
    ok = pcall(function()
        ok2, data = pcall(function()
            return HttpService:JSONDecode(readfile(TAKEN_FILE))
        end)
    end)
    return (ok and ok2 and type(data)=="table") and data or {}
end

local function writeTakenRaw(list)
    pcall(function() writefile(TAKEN_FILE, HttpService:JSONEncode(list)) end)
end

local function cleanTaken(list)
    local now, clean = os.time(), {}
    for _, e in ipairs(list) do
        if type(e)=="table" and e.jobId and (now-(e.ts or 0)) < STALE_SECS then
            table.insert(clean, e)
        end
    end
    return clean
end

local function removeSelf()
    local list = cleanTaken(readTaken())
    local out  = {}
    for _, e in ipairs(list) do
        if e.jobId ~= MY_JOB then table.insert(out, e) end
    end
    writeTakenRaw(out)
end

local function registerSelf()
    local list = cleanTaken(readTaken())
    local out  = {}
    for _, e in ipairs(list) do
        if e.jobId ~= MY_JOB then table.insert(out, e) end
    end
    table.insert(out, { jobId=MY_JOB, user=LocalPlayer.Name, ts=os.time() })
    writeTakenRaw(out)
end

local function isTaken(jobId)
    local now = os.time()
    for _, e in ipairs(readTaken()) do
        if type(e)=="table" and e.jobId==jobId and (now-(e.ts or 0)) < STALE_SECS then
            return true
        end
    end
    return false
end

