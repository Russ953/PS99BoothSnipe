    local function calcBuyAmount(target, insta, diamond, stock, gems, price)
        local base = math.min(stock, math.floor(gems/price))
        if target.Priority=="insta"   then return base end
        if target.Priority=="diamond" then
            if diamond >= insta then return 0 end
            return math.min(base, insta-diamond)
        end
        return base
    end

    local function terminalSearch(termClass, termId)
        local net = ReplicatedStorage:FindFirstChild("Network")
        if not net then return nil end
        local rem = net:FindFirstChild("TradingTerminal_Search")
        if not rem then return nil end
        local ok, res = pcall(function()
            return rem:InvokeServer(termClass, '{"id":"'..termId..'"}', nil, true)
        end)
        if not ok or type(res)~="table" then return nil end
        return res.job_id and res or nil
    end

    local function doServerHop()
        if currentRunID ~= _G.BoothSniperRunID then return end
        local insta, diamond = getInventoryCounts()

        if _G.BoothSniperSettings.TerminalSearch then
            local instaItem, diamondItem, others = nil, nil, {}
            for _, t in ipairs(_G.BoothSniperSettings.Items) do
                if     t.Priority=="insta"   then instaItem=t
                elseif t.Priority=="diamond" then diamondItem=t
                else   table.insert(others,t)
                end
            end
            local order = {}
            if instaItem then table.insert(order, instaItem) end
            for _, t in ipairs(others) do table.insert(order,t) end
            if diamondItem and diamond < insta then table.insert(order, diamondItem) end

            for _, target in ipairs(order) do
                if not target.ItemName then continue end
                local tc  = target.TerminalClass or "Misc"
                local tid = target.TerminalID or target.ItemName
                updateDebug(string.format("🗳️ Terminal: %s...", target.ItemName))
                local entry = terminalSearch(tc, tid)
                if entry and entry.job_id ~= MY_JOB and not isTaken(entry.job_id) then
                    alertDebug(string.format("🗳️ Joining for '%s'", target.ItemName), 4)
                    removeSelf()
                    TeleportService:TeleportToPlaceInstance(entry.place_id or game.PlaceId, entry.job_id, LocalPlayer)
                    task.wait(10); isHopping=false; timeInServer=0
                    return
                end
            end
            updateDebug("⚠️ No terminal result, random hop...")
        end

        if _G.BoothSniperSettings.RandomJoin then
            local url = "https://games.roblox.com/v1/games/"..game.PlaceId.."/servers/Public?sortOrder=Desc&limit=100"
            local ok, res = pcall(function() return game:HttpGet(url) end)
            if ok and res and res~="" then
                local rok, rdata = pcall(function() return HttpService:JSONDecode(res) end)
                if rok and rdata and rdata.data then
                    local cands = {}
                    for _, s in ipairs(rdata.data) do
                        if s.playing and s.maxPlayers
                            and s.playing < s.maxPlayers
                            and s.id ~= MY_JOB
                            and not isTaken(s.id) then
                            table.insert(cands, s)
                        end
                    end
                    table.sort(cands, function(a,b) return (a.playing or 0)>(b.playing or 0) end)
                    if #cands > 0 then
                        removeSelf()
                        TeleportService:TeleportToPlaceInstance(game.PlaceId, cands[1].id, LocalPlayer)
                        task.wait(10)
                    end
                end
            end
        end
        isHopping=false; timeInServer=0
    end

    local function getCleanID(v) return v and tostring(v):match("%d+") or "" end

    local function purchaseItem(ownerID, guid, amount)
        return pcall(function()
            return ReplicatedStorage:WaitForChild("Network")
                :WaitForChild("Booths_RequestPurchase")
                :InvokeServer(
                    tonumber(ownerID),
                    {[tostring(guid)]=tonumber(amount)},
                    {Caller={
                        LineNumber=527,ScriptClass="ModuleScript",Variadic=false,
                        Traceback="ReplicatedStorage.Library.Client.BoothCmds:527 function PromptPurchase2\nReplicatedStorage.Library.Client.BoothCmds:654 function promptOtherPlayerBooth2\nReplicatedStorage.Library.Client.BoothCmds:157",
                        ScriptPath="ReplicatedStorage.Library.Client.BoothCmds",
                        FunctionName="PromptPurchase2",
                        Handle="function: 0xfa15618739cde075",
                        ScriptType="Instance",ParameterCount=2,
                        SourceIdentifier="ReplicatedStorage.Library.Client.BoothCmds"
                    }}
                )
        end)
    end

    local function scanAllBooths()
        if currentRunID ~= _G.BoothSniperRunID or isHopping then return end
        timeInServer += _G.BoothSniperSettings.ScanDelay
        local myGems = getGems()
        local insta, diamond = getInventoryCounts()

        updateDebug(string.format("🎯 Sniping | 💎%d | 🌱%d 🔷%d | Hop:%ds",
            myGems, insta, diamond,
            math.max(0, math.floor((_G.BoothSniperSettings.HopDelay or 5)-timeInServer))))

        -- throttled status push
        scheduleWebhook("🎯 Sniping", myGems, insta, diamond)

        if myGems < 100000 then
            isScanning = false
            alertDebug("💸 Gems drained! Farming...", 5)
            scheduleWebhook("💸 Gems drained", myGems, insta, diamond)
            removeSelf(); removeMyStatus()
            TeleportService:Teleport(8737899170, LocalPlayer)
            return
        end

        local boothsFolder = workspace:FindFirstChild("__THINGS")
            and workspace.__THINGS:FindFirstChild("Booths")
        if not boothsFolder then return end

        for _, booth in ipairs(boothsFolder:GetChildren()) do
            local ownerID = booth:GetAttribute("Owner")
            if not ownerID or ownerID==LocalPlayer.UserId then continue end
            local petScroll = booth:FindFirstChild("Pets")
                and booth.Pets:FindFirstChild("BoothTop")
                and booth.Pets.BoothTop:FindFirstChild("PetScroll")
            if not petScroll then continue end

            for _, itemBox in ipairs(petScroll:GetChildren()) do
                if itemBox:IsA("UIListLayout") or itemBox:IsA("UIPadding") then continue end
                local iconLabel = itemBox:FindFirstChild("Holder")
                    and itemBox.Holder:FindFirstChild("ItemSlot")
                    and itemBox.Holder.ItemSlot:FindFirstChild("Icon")
                if not (iconLabel and iconLabel:IsA("ImageLabel")) then continue end

                local cleanID = getCleanID(iconLabel.Image)
                local guid    = itemBox.Name
                for _, target in ipairs(_G.BoothSniperSettings.Items) do
                    if not target.AssetID then continue end
                    if cleanID ~= getCleanID(target.AssetID) then continue end
                    local costLabel = itemBox:FindFirstChild("Buy") and itemBox.Buy:FindFirstChild("Cost")
                    if not (costLabel and costLabel:IsA("TextLabel")) then continue end

                    local price = parsePrice(costLabel.Text)
                    local maxP  = target.MaxPrice or math.huge
                    local name  = target.ItemName or target.AssetID
                    if seenItems[guid] then continue end

                    if price > maxP then seenItems[guid]=true; continue end

                    local stock  = tonumber(itemBox:GetAttribute("Quantity")) or 1
                    local buyAmt = calcBuyAmount(target, insta, diamond, stock, myGems, price)

                    if buyAmt <= 0 then
                        if target.Priority=="diamond" then
                            alertDebug(string.format("⚖️ SKIP Diamond | 🔷%d >= 🌱%d", diamond, insta), 2)
                        end
                        seenItems[guid]=true; continue
                    end

                    seenItems[guid] = true
                    alertDebug(string.format("⌛ FOUND %s | %s | x%d", name, costLabel.Text, buyAmt), 4)

                    task.spawn(function()
                        local startGems = getGems()
                        local ok, resp  = purchaseItem(ownerID, guid, buyAmt)
                        task.wait(0.5)
                        if ok and (resp==true or getGems()<startGems) then
                            alertDebug(string.format("✅ BOUGHT %s x%d @ %s", name, buyAmt, costLabel.Text), 4)
                            if target.Priority=="diamond" then diamond+=buyAmt
                            elseif target.Priority=="insta" then insta+=buyAmt
                            end
                            lastWebhookPush = 0  -- force immediate update on buy
                            scheduleWebhook(string.format("✅ Bought %s x%d", name, buyAmt), getGems(), insta, diamond)
                        else
                            seenItems[guid] = nil
                        end
                    end)
                    task.wait(1); timeInServer=0
                end
            end
        end

        if _G.BoothSniperSettings.AutoHop and timeInServer >= (_G.BoothSniperSettings.HopDelay or 5) then
            isHopping = true
            task.spawn(doServerHop)
        end
    end

    -- wait for inventory to be fully loaded before first webhook send
    task.spawn(function()
        waitForInventory()
        local i, d = getInventoryCounts()
        lastWebhookPush = 0
        scheduleWebhook("✅ Online", getGems(), i, d)
    end)

    task.spawn(function()
        while isScanning do
            if currentRunID ~= _G.BoothSniperRunID then break end
            pcall(scanAllBooths)
            task.wait(_G.BoothSniperSettings.ScanDelay)
        end
    end)
end

-- ========================================================================
-- TELEPORT QUEUE
-- ========================================================================
local qot = queue_on_teleport
    or (syn and syn.queue_on_teleport)
    or getgenv().queue_on_teleport
if _G.BoothSniperSettings.AutoExecute and qot and not _G.BoothSniperQueueSet then
    _G.BoothSniperQueueSet = true
    LocalPlayer.OnTeleport:Connect(function()
        local settingsJSON = HttpService:JSONEncode(_G.BoothSniperSettings)
        local script = string.format([[
            if not game:IsLoaded() then game.Loaded:Wait() end
            task.wait(3)
            if _G.BoothSniperServerHopLoaded then return end
            local HttpService = game:GetService("HttpService")
            _G.BoothSniperSettings = HttpService:JSONDecode([=[%s]=])
            loadstring(game:HttpGet("https://raw.githubusercontent.com/Russ953/PS99BoothSnipe/refs/heads/main/AutoGemFarm_Garden"))()
        ]], settingsJSON)
        pcall(function() qot(script) end)
    end)
end
