local function sendOrUpdateWebhook(status, instaCount, diamondCount)
    if WEBHOOK == "" then return end
    local body = buildEmbed(status, instaCount, diamondCount)
    task.spawn(function()
        if webhookMsgId then
            -- PATCH existing message
            pcall(function()
                local reqFunc = syn and syn.request or request or http_request
                if not reqFunc then return end
                reqFunc({
                    Url     = WEBHOOK .. "/messages/" .. webhookMsgId,
                    Method  = "PATCH",
                    Headers = { ["Content-Type"] = "application/json" },
                    Body    = HttpService:JSONEncode(body)
                })
            end)
        else
            -- POST new message, capture ID
            pcall(function()
                local reqFunc = syn and syn.request or request or http_request
                if not reqFunc then return end
                local res = reqFunc({
                    Url     = WEBHOOK .. "?wait=true",
                    Method  = "POST",
                    Headers = { ["Content-Type"] = "application/json" },
                    Body    = HttpService:JSONEncode(body)
                })
                if res and res.Body then
                    local ok, data = pcall(function() return HttpService:JSONDecode(res.Body) end)
                    if ok and data and data.id then
                        webhookMsgId = data.id
                    end
                end
            end)
        end
    end)
end

