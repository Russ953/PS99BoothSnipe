local webhookMsgId = nil  -- we'll store the message ID to PATCH it

local function webhookRequest(method, url, body)
    if WEBHOOK == "" then return nil end
    local ok, res = pcall(function()
        return syn and syn.request or request or http_request or (function() return nil end)
    end)
    local reqFunc = ok and res or nil
    if not reqFunc then return nil end
    local r = pcall(function()
        reqFunc({
            Url     = url,
            Method  = method,
            Headers = { ["Content-Type"] = "application/json" },
            Body    = HttpService:JSONEncode(body)
        })
    end)
end

