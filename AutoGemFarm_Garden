    -- clean stale, remove my old entry
    for _, e in ipairs(list) do
        if type(e)=="table" and e.name and e.name ~= MY_NAME
            and (now-(e.ts or 0)) < STALE_SECS then
            table.insert(out, e)
        end
    end
    table.insert(out, {
        name=MY_NAME, status=status,
        gems=gems or getGems(),
        insta=insta or 0, diamond=diamond or 0,
        server=tostring(MY_JOB):sub(1,18).."...",
        ts=now
    })
    safeWriteJSON(STATUS_FILE, out)
    return out
end
local function removeMyStatus()
    local list = safeReadJSON(STATUS_FILE)
    local out  = {}
    for _, e in ipairs(list) do
        if type(e)=="table" and e.name ~= MY_NAME then table.insert(out, e) end
    end
    safeWriteJSON(STATUS_FILE, out)
end

