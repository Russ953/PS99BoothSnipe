                    if item.configName and item.configName:lower() == itemName:lower() and item.configData and item.configData.Icon then
                        local id = tostring(item.configData.Icon):match("%d+")
                        if id then cachedAssetIDs[cacheKey] = id; return id end
                    end
                end
            end
        end
        return nil
    end

