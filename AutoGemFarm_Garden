    -- inventory reader
    local function getInventoryCounts()
        local insta, diamond = 0, 0
        pcall(function()
            local content = LocalPlayer.PlayerGui
                :WaitForChild("Main",5):WaitForChild("HotbarMain",5):WaitForChild("Content",5)
