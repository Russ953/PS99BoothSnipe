        addLog = function(msg, color)
            local lbl = Instance.new("TextLabel", LogFrame)
            lbl.Size = UDim2.new(1, -5, 0, 16)
            lbl.BackgroundTransparency = 1
            lbl.Text = " " .. msg
            lbl.TextColor3 = color or Color3.fromRGB(200, 200, 200)
            lbl.TextSize = 12
            lbl.Font = Enum.Font.Gotham
            lbl.TextXAlignment = Enum.TextXAlignment.Left
            task.spawn(function() task.wait(0.05) LogFrame.CanvasPosition = Vector2.new(0, LogList.AbsoluteContentSize.Y) end)
        end

        task.spawn(function()
            while isScanning do
                if currentRunID ~= _G.BoothSniperRunID then break end
                pcall(function() scanAllBooths(nil) end)
                task.wait(_G.BoothSniperSettings.ScanDelay)
            end
        end)
    end
