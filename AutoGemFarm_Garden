    local timeInServer = 0
    local statusTimeout = 0 
    local cachedAssetIDs = {}
    local seenItems = {}
    local addLog = function(msg, color) end
    
    local function extractJobId(tbl)
        if type(tbl) == "string" and #tbl == 36 and tbl:match("%w+-%w+-%w+-%w+-%w+") then return tbl
        elseif type(tbl) == "table" then
            if tbl.jobId then return tbl.jobId, tbl.placeId end
            if tbl.JobId then return tbl.JobId, tbl.PlaceId end
            for _, v in pairs(tbl) do local j, p = extractJobId(v); if j then return j, p end end
        end
        return nil
    end
    
    local function doServerHop(statusLabel)
        if currentRunID ~= _G.BoothSniperRunID then return end
        
        if _G.BoothSniperSettings.RandomJoin then
            if statusLabel then statusLabel.Text = "🎲 Random Hopping..."; statusTimeout = os.time() + 5 end
            local url = "https://games.roblox.com/v1/games/" .. game.PlaceId .. "/servers/Public?sortOrder=Desc&limit=100"
            local success, result = pcall(function() return game:HttpGet(url) end)
            
            if success and result and result ~= "" then
                local decodeSuccess, data = pcall(function() return HttpService:JSONDecode(result) end)
                if decodeSuccess and data and data.data then
                    local validServers = {}
                    for _, server in ipairs(data.data) do
                        if server.playing and server.maxPlayers and server.playing < server.maxPlayers and server.id ~= game.JobId then
                            table.insert(validServers, server.id)
                        end
                    end
                    if #validServers > 0 then
                        TeleportService:TeleportToPlaceInstance(game.PlaceId, validServers[math.random(1, #validServers)], LocalPlayer)
                        task.wait(10)
                    end
                end
            end
        end
        isHopping = false
        timeInServer = 0 
    end

    local function fetchItemAssetID(class, itemName)
        local cacheKey = class .. "_" .. itemName
        if cachedAssetIDs[cacheKey] then return cachedAssetIDs[cacheKey] end
        local ok, result = pcall(function() return game:HttpGet(string.format("https://ps99.biggamesapi.io/api/collection/%s", class)) end)
        if ok and result then
            local decoded = HttpService:JSONDecode(result)
            if decoded and decoded.data then
                for _, item in pairs(decoded.data) do
                    if item.configName and item.configName:lower() == itemName:lower() and item.configData and item.configData.Icon then
                        local id = tostring(item.configData.Icon):match("%d+")
                        if id then cachedAssetIDs[cacheKey] = id; return id end
                    end
                end
            end
        end
        return nil
    end

    for _, t in ipairs(_G.BoothSniperSettings.Items) do
        if t.Class and t.ItemName and not t.AssetID then
            local id = fetchItemAssetID(t.Class, t.ItemName)
            if id then t.AssetID = id end
        end
    end

    local function getCleanID(assetText) return assetText and tostring(assetText):match("%d+") or "" end

    local function purchaseItem(ownerID, itemGUID, amount)
        local args = { tonumber(ownerID), { [tostring(itemGUID)] = tonumber(amount) }, { Caller = { LineNumber = 527, ScriptClass = "ModuleScript", Variadic = false, Traceback = "ReplicatedStorage.Library.Client.BoothCmds:527", ScriptPath = "ReplicatedStorage.Library.Client.BoothCmds", FunctionName = "PromptPurchase2" } } }
        local success, response = pcall(function() return game:GetService("ReplicatedStorage"):WaitForChild("Network"):WaitForChild("Booths_RequestPurchase"):InvokeServer(unpack(args)) end)
        return success, response
    end

    local function scanAllBooths(statusLabel)
        if currentRunID ~= _G.BoothSniperRunID or isHopping then return end 
        timeInServer = timeInServer + _G.BoothSniperSettings.ScanDelay
        
        local myGems = getGems()
        updateDebug(string.format("🎯 Sniping | Gems: %d | Hop In: %ds", myGems, math.max(0, math.floor((_G.BoothSniperSettings.HopDelay or 5) - timeInServer))))
        
        if myGems < 100000 then
            isScanning = false
            updateDebug("💸 Gems drained! TPing to Farm...")
            addLog("💸 Gems drained! TPing to Main Game...", Color3.fromRGB(150, 150, 255))
            TeleportService:Teleport(8737899170, LocalPlayer)
            return
        end

        local boothsFolder = workspace:FindFirstChild("__THINGS") and workspace.__THINGS:FindFirstChild("Booths")
        if not boothsFolder then return end

        for _, booth in ipairs(boothsFolder:GetChildren()) do
            local ownerID = booth:GetAttribute("Owner")
            if not ownerID or ownerID == LocalPlayer.UserId then continue end 

            local petScroll = booth:FindFirstChild("Pets") and booth.Pets:FindFirstChild("BoothTop") and booth.Pets.BoothTop:FindFirstChild("PetScroll")
            if petScroll then
                for _, itemBox in ipairs(petScroll:GetChildren()) do
                    if itemBox:IsA("UIListLayout") or itemBox:IsA("UIPadding") then continue end
                    local iconLabel = itemBox:FindFirstChild("Holder") and itemBox.Holder:FindFirstChild("ItemSlot") and itemBox.Holder.ItemSlot:FindFirstChild("Icon")

                    if iconLabel and iconLabel:IsA("ImageLabel") then
                        local cleanFoundID = getCleanID(iconLabel.Image)
                        local guid = itemBox.Name

                        for _, target in ipairs(_G.BoothSniperSettings.Items) do
                            if target.AssetID and cleanFoundID == getCleanID(target.AssetID) then
                                local costLabel = itemBox:FindFirstChild("Buy") and itemBox.Buy:FindFirstChild("Cost")
                                if costLabel and costLabel:IsA("TextLabel") then
                                    local pricePerItem = parsePrice(costLabel.Text)
                                    local maxPrice = target.MaxPrice or math.huge
                                    local itemNameDisplay = target.ItemName or target.AssetID
                                    
                                    if not seenItems[guid] then
                                        seenItems[guid] = true
                                        if pricePerItem <= maxPrice then
                                            local stockAvailable = tonumber(itemBox:GetAttribute("Quantity")) or 1
                                            local maxAffordable = math.floor(myGems / pricePerItem)
                                            local buyAmount = math.min(maxAffordable, stockAvailable)
                                            
                                            if buyAmount > 0 then
                                                addLog(string.format("⌛ Buying %dx %s...", buyAmount, itemNameDisplay), Color3.fromRGB(200, 200, 100))
                                                task.spawn(function() 
                                                    local startGems = getGems()
                                                    local success, response = purchaseItem(ownerID, guid, buyAmount)
                                                    task.wait(0.5) 
                                                    if success and (response == true or getGems() < startGems) then
                                                        addLog(string.format("✅ Bought %s!", itemNameDisplay), Color3.fromRGB(100, 255, 130))
                                                    else
                                                        seenItems[guid] = nil 
                                                    end
                                                end)
                                                task.wait(1) 
                                                timeInServer = 0 
                                            end
                                        end
                                    end
                                end
                            end
                        end
                    end
                end
            end
        end

        if _G.BoothSniperSettings.AutoHop and timeInServer >= (_G.BoothSniperSettings.HopDelay or 5) then
            isHopping = true
            task.spawn(function() doServerHop(statusLabel) end)
            return
