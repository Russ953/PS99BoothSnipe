local function safeReadJSON(file)
    local ok1, ok2, data
    ok1 = pcall(function() ok2, data = pcall(function()
        return HttpService:JSONDecode(readfile(file))
    end) end)
    return (ok1 and ok2 and type(data)=="table") and data or {}
end
local function safeWriteJSON(file, tbl)
    pcall(function() writefile(file, HttpService:JSONEncode(tbl)) end)
end
local function safeReadText(file)
    local ok, val = pcall(function() return readfile(file) end)
    return (ok and type(val)=="string") and val or ""
end
local function safeWriteText(file, val)
    pcall(function() writefile(file, tostring(val)) end)
end
local function fileExists(file)
    local ok, res = pcall(isfile, file)
    return ok and res
end

